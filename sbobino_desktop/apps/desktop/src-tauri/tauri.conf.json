{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sbobino Desktop",
  "version": "0.1.0",
  "identifier": "com.sbobino.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sbobino Desktop",
        "width": 1320,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "endpoints": [
        "https://github.com/pietroMastro92/sbobbino/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
