{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sbobino",
  "version": "0.1.5",
  "identifier": "com.sbobino.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Sbobino",
        "width": 1320,
        "height": 860,
        "minWidth": 560,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "resources/pyannote"
    ],
    "externalBin": [
      "binaries/whisper-cli",
      "binaries/whisperkit-cli",
      "binaries/whisper-stream",
      "binaries/ffmpeg"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/pietroMastro92/sbobino_tauri/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
